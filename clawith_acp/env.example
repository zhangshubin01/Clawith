# 复制本文件为 .env，按实际环境修改（setup 脚本不会自动创建 .env）

# 云端或局域网 Clawith 后端根地址（勿尾斜杠）
CLAWITH_URL=http://127.0.0.1:8008

# 用户在 Clawith Web 端生成的 API Key（cw- 开头）
CLAWITH_API_KEY=cw-your-key-here

# 智能体：填名称（如 WL4）或 UUID
CLAWITH_DEFAULT_AGENT_ID=WL4

# 可选：WebSocket 是否走系统代理。留空=直连（推荐，避免 SOCKS 缺 python-socks）
# CLAWITH_WS_PROXY=direct
# CLAWITH_WS_PROXY=auto

# 可选：IDE session_update 超时（秒），避免 JetBrains 侧卡住导致 Chat 一直「正在等待」
# CLAWITH_ACP_SESSION_UPDATE_TIMEOUT_SEC=120

# 可选：与官方 echo_agent 一致，传给 session_update 的 source（默认 clawith-acp-thin）
# CLAWITH_ACP_SESSION_UPDATE_SOURCE=clawith-acp-thin

# 可选：详细日志（stderr）：chunk 长度、每条 IDE session_update 成功与 kind/耗时（排查「工具完成仍等待」）
# CLAWITH_ACP_VERBOSE=1
# 或：CLAWITH_ACP_LOG_LEVEL=DEBUG

# 后端 uvicorn 排障（与上同一 shell 或 systemd Environment=）：详细 ACP WebSocket / LLM 流式摘要
# CLAWITH_ACP_VERBOSE=1
# 每条 outbound chunk 一行（极吵）：CLAWITH_ACP_LOG_CHUNKS=1

# 本地源码跑后端时，请用仓库根目录 ./restart.sh --source，日志在 ~/.clawith/data/log/clawith_YYYY-MM-DD.log；
# 勿在 IDE 里再起第二个 uvicorn:8008，否则 pid 与日志对不上、grep [ACP] 看不到当前会话。
